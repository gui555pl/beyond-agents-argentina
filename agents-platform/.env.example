# Chave da Anthropic para o modelo Claude.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Servidor HTTP+SSE
PORT=4001

# Quantas runs podem rodar em paralelo no worker pool (default 3).
MAX_CONCURRENT_RUNS=3

# Caminho do SQLite com submissões e events. Default: ./data/runs.sqlite
DATABASE_PATH=./data/runs.sqlite

# Limite de POST /api/submissions por IP por minuto (default 15 — demo).
# Use 0 para desligar. Em produção pública aberta, considere 3–5.
# SUBMISSION_RATE_LIMIT=15

# TIMEOUT_POR_NO_MS=300000

# DEMO_FAST_VALIDATION=true  # substitui o Validador Aurora LLM por mock determinístico
# DEMO_FAST_ORCHESTRATOR=true  # substitui o Orquestrador LLM por árvore de regras

# Tool Runcomfy (geração de imagem). Opcional.
RUNCOMFY_API_URL=
RUNCOMFY_API_KEY=
